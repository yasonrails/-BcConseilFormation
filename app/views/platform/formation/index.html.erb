<% content_for :page_title do %>Espace <em>apprenant</em><% end %>

<div style="margin-bottom:16px;" class="rb">
  <div>
    <div class="lbl" style="margin-bottom:4px;">Espace apprenant</div>
    <h1 style="font-family:var(--serif);font-size:28px;font-weight:300;letter-spacing:-.02em;">
      <%= @formation_titre.split("&").first.strip %> <em style="font-style:italic;color:var(--ink-60)">&amp; <%= @formation_titre.split("&").last.strip %></em>
    </h1>
  </div>
  <span class="tag tb" style="font-size:12px;padding:6px 14px;"><%= @progression %>% complété</span>
</div>

<div style="margin-bottom:18px;">
  <div class="pb" style="height:7px;border-radius:4px;">
    <div class="pf" style="width:<%= @progression %>%"></div>
  </div>
</div>

<div class="g2" style="align-items:start;">
  <!-- PROGRAMME -->
  <div>
    <div class="lbl" style="margin-bottom:10px;">Programme</div>
    <% @modules.each do |m| %>
      <div class="mi <%= 'open' if m[:statut] == :current %>">
        <div class="mh" <%= 'onclick="toggleMod(this)"'.html_safe if m[:statut] == :current %>>
          <div class="ms <%= { done: 'done', current: 'curr', locked: 'lock' }[m[:statut]] %>">
            <%= case m[:statut]
                when :done    then "✓"
                when :current then "▶"
                when :locked  then "🔒"
                end %>
          </div>
          <div class="minfo">
            <div class="mtitle">Module <%= m[:numero] %> — <%= m[:titre] %></div>
            <div class="msub" <%= 'style="color:var(--accent)"'.html_safe if m[:statut] == :current %>><%= m[:sous] %></div>
          </div>
          <span class="mdur"><%= m[:duree] %></span>
        </div>
        <% if m[:statut] == :current %>
          <div class="mexp">
            <p style="margin-bottom:10px;">Ce module couvre l'identification des talents, les plans de développement individuels et la gestion des compétences clés.</p>
            <div style="margin-bottom:10px;"><div class="pb"><div class="pf" style="width:45%"></div></div></div>
            <button class="btn ba bs">Continuer le module →</button>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- COLONNE DROITE -->
  <div>
    <!-- Formateur -->
    <div class="card" style="margin-bottom:14px;padding:20px;">
      <div class="ts" style="margin-bottom:14px;">Votre formateur</div>
      <div class="row" style="margin-bottom:12px;">
        <div class="ava" style="width:40px;height:40px;border-radius:50%;background:linear-gradient(135deg,#1c5fff,#6366f1);font-size:14px;">SR</div>
        <div>
          <div style="font-weight:600;font-size:13px;">Sophie Renard</div>
          <div class="bxxs">Experte RH · 12 ans d'expérience</div>
        </div>
      </div>
      <%= link_to "Envoyer un message", platform_messagerie_path, class: "btn bo", style: "width:100%;justify-content:center;font-size:12px;" %>
    </div>

    <!-- Certificat -->
    <div class="card" style="padding:20px;margin-bottom:14px;">
      <div style="background:linear-gradient(135deg,var(--ink) 0%,#1a1a2e 100%);border-radius:var(--r12);padding:22px;text-align:center;position:relative;overflow:hidden;">
        <div style="position:absolute;inset:0;background:repeating-linear-gradient(-45deg,transparent,transparent 18px,rgba(255,255,255,.02) 18px,rgba(255,255,255,.02) 19px);"></div>
        <div style="font-size:24px;margin-bottom:8px;position:relative;">🏅</div>
        <div style="font-family:var(--serif);font-size:16px;font-weight:300;color:#fff;position:relative;">Certificat de formation</div>
        <div style="font-size:10px;color:rgba(255,255,255,.35);letter-spacing:.06em;text-transform:uppercase;position:relative;margin-top:4px;">Disponible au module 7</div>
      </div>
    </div>

    <!-- Ressources -->
    <div class="card" style="padding:20px;">
      <div class="ts" style="margin-bottom:12px;">Ressources</div>
      <div style="display:flex;flex-direction:column;gap:7px;">
        <div style="display:flex;align-items:center;gap:8px;padding:9px;background:var(--sand);border-radius:var(--r8);cursor:pointer;font-size:12px;">📄 Guide — Identifier les talents.pdf</div>
        <div style="display:flex;align-items:center;gap:8px;padding:9px;background:var(--sand);border-radius:var(--r8);cursor:pointer;font-size:12px;">📊 Matrice des compétences.xlsx</div>
        <div style="display:flex;align-items:center;gap:8px;padding:9px;background:var(--sand);border-radius:var(--r8);cursor:pointer;font-size:12px;">🎬 Replay session live 15 jan.</div>
      </div>

      <!-- Fonctionnalités IA -->
      <div style="margin-top:20px;">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px;padding:0 2px;">
          <div style="width:26px;height:26px;border-radius:var(--r8);background:linear-gradient(135deg,#1c5fff,#8b5cf6);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="white" stroke-width="1.5"><circle cx="8" cy="8" r="3"/><path d="M8 1v2M8 13v2M1 8h2M13 8h2M3.05 3.05l1.42 1.42M11.54 11.54l1.41 1.41"/></svg>
          </div>
          <span style="font-size:12px;font-weight:600;color:var(--ink);letter-spacing:.02em;">Fonctionnalités IA de ce module</span>
          <span style="font-size:9px;background:linear-gradient(135deg,#1c5fff,#8b5cf6);color:#fff;padding:2px 8px;border-radius:10px;font-weight:700;letter-spacing:.06em;">BETA</span>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:9px;">
          <div class="ai-plat-card" onclick="openAiPanel('tutor')">
            <div class="ai-plat-icon" style="background:linear-gradient(135deg,rgba(28,95,255,.12),rgba(139,92,246,.08));"><svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="#6366f1" stroke-width="1.5"><path d="M1 3h14M1 7h10M1 11h7"/><circle cx="13" cy="11" r="2.5"/></svg></div>
            <div class="ai-plat-content"><div class="ai-plat-title">Tuteur IA</div><div class="ai-plat-desc">Questions & explications personnalisées</div></div>
            <div class="ai-plat-arrow">→</div>
          </div>
          <div class="ai-plat-card" onclick="openAiPanel('quiz')">
            <div class="ai-plat-icon" style="background:linear-gradient(135deg,rgba(15,146,84,.12),rgba(52,211,153,.06));"><svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="#0f9254" stroke-width="1.5"><path d="M8 1l2 5h5l-4 3 1.5 5L8 11l-4.5 3L5 9 1 6h5z"/></svg></div>
            <div class="ai-plat-content"><div class="ai-plat-title">Quiz adaptatif</div><div class="ai-plat-desc">Ciblé sur vos lacunes identifiées</div></div>
            <div class="ai-plat-arrow">→</div>
          </div>
          <div class="ai-plat-card" onclick="openAiPanel('resume')">
            <div class="ai-plat-icon" style="background:linear-gradient(135deg,rgba(180,83,9,.12),rgba(245,158,11,.06));"><svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="#b45309" stroke-width="1.5"><rect x="2" y="1" width="12" height="14" rx="2"/><path d="M5 5h6M5 8h6M5 11h4"/></svg></div>
            <div class="ai-plat-content"><div class="ai-plat-title">Synthèse auto</div><div class="ai-plat-desc">Résumé intelligent exportable PDF</div></div>
            <div class="ai-plat-arrow">→</div>
          </div>
          <div class="ai-plat-card" onclick="openAiPanel('path')">
            <div class="ai-plat-icon" style="background:linear-gradient(135deg,rgba(124,45,107,.12),rgba(192,68,106,.06));"><svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="#7c2d6b" stroke-width="1.5"><path d="M2 14L6 8l4 3 4-7"/><circle cx="6" cy="8" r="1.5"/><circle cx="10" cy="11" r="1.5"/></svg></div>
            <div class="ai-plat-content"><div class="ai-plat-title">Parcours IA</div><div class="ai-plat-desc">Recommandations personnalisées</div></div>
            <div class="ai-plat-arrow">→</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%# ── AI Modal overlay ── %>
<% content_for :modals do %>
<div id="ai-modal" onclick="closeAiPanel(event)" style="display:none;position:fixed;inset:0;z-index:3000;background:rgba(14,14,14,.45);backdrop-filter:blur(6px);">
  <div id="ai-modal-box" onclick="event.stopPropagation()" style="position:absolute;right:0;top:0;bottom:0;width:460px;background:var(--white);display:flex;flex-direction:column;overflow:hidden;animation:slideIn .35s var(--ease-out);box-shadow:-12px 0 40px rgba(0,0,0,.15);">

    <!-- TUTEUR -->
    <div id="ai-panel-tutor" class="ai-panel-content">
      <div class="ai-panel-header" style="background:linear-gradient(135deg,#1c5fff,#8b5cf6);">
        <div style="font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.55);margin-bottom:5px;">Tuteur IA — Module 4</div>
        <div style="font-family:var(--serif);font-size:20px;font-weight:300;color:#fff;">Gestion des talents</div>
        <button onclick="closeAiPanel()" style="position:absolute;top:14px;right:14px;background:rgba(255,255,255,.12);border:none;color:white;width:28px;height:28px;border-radius:50%;cursor:pointer;font-size:14px;display:flex;align-items:center;justify-content:center;">✕</button>
      </div>
      <div class="ai-panel-chat">
        <div class="ai-msg bot"><div class="ai-msg-avatar" style="background:linear-gradient(135deg,#1c5fff,#8b5cf6)">IA</div><div class="ai-msg-bubble bot">Bonjour 👋 Vous êtes à 45% du module <strong>Gestion des talents</strong>. Comment puis-je vous aider ?</div></div>
        <div class="ai-msg user"><div class="ai-msg-bubble user">Comment évaluer les hauts potentiels dans une PME sans département RH structuré ?</div></div>
        <div class="ai-msg bot"><div class="ai-msg-avatar" style="background:linear-gradient(135deg,#1c5fff,#8b5cf6)">IA</div><div class="ai-msg-bubble bot">Excellente question ! En 3 étapes :<br><br><strong>1. Critères observables</strong> — Initiative, apprentissage rapide, influence sur l'équipe.<br><strong>2. Évaluation 360° informelle</strong> — Avis manager, pairs, client interne.<br><strong>3. Mise en situation</strong> — Projet transverse et observation des comportements.<br><br>Voulez-vous une grille d'évaluation adaptée ?</div></div>
      </div>
      <div class="ai-panel-input">
        <input type="text" placeholder="Posez votre question…" class="ai-input-field">
        <button class="btn ba bs">↑</button>
      </div>
    </div>

    <!-- QUIZ -->
    <div id="ai-panel-quiz" class="ai-panel-content" style="display:none;">
      <div class="ai-panel-header" style="background:linear-gradient(135deg,#0f9254,#34d399);">
        <div style="font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.55);margin-bottom:5px;">Quiz adaptatif IA</div>
        <div style="font-family:var(--serif);font-size:20px;font-weight:300;color:#fff;">3 lacunes ciblées</div>
        <button onclick="closeAiPanel()" style="position:absolute;top:14px;right:14px;background:rgba(255,255,255,.12);border:none;color:white;width:28px;height:28px;border-radius:50%;cursor:pointer;font-size:14px;display:flex;align-items:center;justify-content:center;">✕</button>
      </div>
      <div style="padding:20px;flex:1;overflow-y:auto;">
        <div style="background:var(--green-bg);border-radius:var(--r8);padding:12px;margin-bottom:18px;border:1px solid rgba(15,146,84,.15);font-size:12px;"><strong style="color:var(--green);">IA a analysé votre profil</strong> — Quiz généré sur : matrice 9-box, plans de développement, coût du turnover.</div>
        <div style="font-size:12px;font-weight:600;margin-bottom:12px;">Question 1 / 5</div>
        <div style="font-family:var(--serif);font-size:18px;font-weight:400;line-height:1.4;margin-bottom:16px;">Dans la matrice 9-box, un collaborateur "Haute Performance / Faible Potentiel" doit être :</div>
        <div style="display:flex;flex-direction:column;gap:8px;">
          <button class="quiz-opt" onclick="selectQuiz(this,false)">A — Licencié pour optimiser les coûts</button>
          <button class="quiz-opt" onclick="selectQuiz(this,false)">B — Promu immédiatement</button>
          <button class="quiz-opt" onclick="selectQuiz(this,true)">C — Valorisé et fidélisé dans son poste</button>
          <button class="quiz-opt" onclick="selectQuiz(this,false)">D — Ignoré car sans potentiel d'évolution</button>
        </div>
        <div id="quiz-feedback" style="display:none;margin-top:14px;padding:12px;border-radius:var(--r8);background:var(--green-bg);border:1px solid rgba(15,146,84,.15);">
          <div style="font-weight:600;color:var(--green);margin-bottom:3px;font-size:13px;">✓ Bonne réponse !</div>
          <div style="font-size:12px;">Les "Stars solides" sont fidélisées via reconnaissance, missions enrichissantes et récompenses.</div>
        </div>
      </div>
    </div>

    <!-- SYNTHÈSE -->
    <div id="ai-panel-resume" class="ai-panel-content" style="display:none;">
      <div class="ai-panel-header" style="background:linear-gradient(135deg,#b45309,#f59e0b);">
        <div style="font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.55);margin-bottom:5px;">Synthèse IA — Module 4</div>
        <div style="font-family:var(--serif);font-size:20px;font-weight:300;color:#fff;">Gestion des talents</div>
        <button onclick="closeAiPanel()" style="position:absolute;top:14px;right:14px;background:rgba(255,255,255,.12);border:none;color:white;width:28px;height:28px;border-radius:50%;cursor:pointer;font-size:14px;display:flex;align-items:center;justify-content:center;">✕</button>
      </div>
      <div style="padding:20px;flex:1;overflow-y:auto;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;"><div style="font-size:11px;color:var(--ink-60);">Généré le 1 mar. 2026 · 45% complété</div><button class="btn bo bs">📥 PDF</button></div>
        <div style="border-left:3px solid #f59e0b;padding-left:14px;margin-bottom:16px;">
          <div style="font-size:10px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:#b45309;margin-bottom:8px;">Points clés retenus</div>
          <ul style="list-style:none;display:flex;flex-direction:column;gap:6px;">
            <li style="font-size:12px;display:flex;gap:7px;"><span style="color:#f59e0b;">›</span><span>La <strong>matrice 9-box</strong> croise performance et potentiel en 3×3 niveaux</span></li>
            <li style="font-size:12px;display:flex;gap:7px;"><span style="color:#f59e0b;">›</span><span>Les <strong>hauts potentiels</strong> représentent 15% des effectifs mais 30% de la valeur créée</span></li>
            <li style="font-size:12px;display:flex;gap:7px;"><span style="color:#f59e0b;">›</span><span>Un <strong>PDI</strong> combine formation, mentoring et mobilité interne</span></li>
          </ul>
        </div>
      </div>
    </div>

    <!-- PARCOURS -->
    <div id="ai-panel-path" class="ai-panel-content" style="display:none;">
      <div class="ai-panel-header" style="background:linear-gradient(135deg,#7c2d6b,#c0446a);">
        <div style="font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.55);margin-bottom:5px;">Parcours IA</div>
        <div style="font-family:var(--serif);font-size:20px;font-weight:300;color:#fff;">Pour <%= current_user&.email&.split("@")&.first&.humanize || "vous" %></div>
        <button onclick="closeAiPanel()" style="position:absolute;top:14px;right:14px;background:rgba(255,255,255,.12);border:none;color:white;width:28px;height:28px;border-radius:50%;cursor:pointer;font-size:14px;display:flex;align-items:center;justify-content:center;">✕</button>
      </div>
      <div style="padding:20px;flex:1;overflow-y:auto;">
        <div style="font-size:12px;color:var(--ink-60);margin-bottom:16px;line-height:1.6;">Basé sur votre profil et les tendances RH 2026, l'IA recommande :</div>
        <div style="background:#fdf0f4;border-radius:var(--r12);padding:14px;border:1px solid rgba(192,68,106,.15);margin-bottom:10px;">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;"><span style="font-size:10px;font-weight:600;letter-spacing:.07em;text-transform:uppercase;color:#c0446a;">Prochaine — 94% compatible</span><span style="font-size:9px;background:#c0446a;color:#fff;padding:2px 8px;border-radius:10px;font-weight:700;">Recommandé</span></div>
          <div style="font-size:14px;font-weight:600;margin-bottom:3px;">People Analytics & Data RH</div>
          <div style="font-size:11px;color:var(--ink-60);margin-bottom:10px;">Analyse RH avec Power BI, indicateurs sociaux.</div>
          <button class="btn bs" style="background:#c0446a;color:#fff;">Ajouter au parcours</button>
        </div>
      </div>
    </div>

  </div>
</div>
<% end %>
