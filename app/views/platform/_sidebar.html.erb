<nav class="sidebar">
  <div class="sb-logo">
    <div class="sb-logo-top">
      <%= link_to platform_dashboard_path, style: "display:flex;align-items:center;gap:8px;text-decoration:none;" do %>
        <div class="sb-brand">BC <em>Formation</em></div>
      <% end %>
      <span class="sb-tag"><%= current_user&.admin? ? "ADMIN" : "LMS" %></span>
    </div>
    <div class="sb-sub"><%= current_user&.admin? ? "Espace administrateur" : "Espace apprenant" %></div>
  </div>

  <% if current_user&.admin? %>
    <%# ─── MENU ADMIN ─── %>
    <div class="sb-section">Tableau de bord</div>
    <%= link_to platform_admin_dashboard_path, class: "nav-item #{request.path == '/plateforme/admin' ? 'active' : ''}" do %>
      <svg class="ni" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="1" width="6" height="6" rx="1.5"/><rect x="9" y="1" width="6" height="6" rx="1.5"/><rect x="1" y="9" width="6" height="6" rx="1.5"/><rect x="9" y="9" width="6" height="6" rx="1.5"/></svg>
      <span>Vue d'ensemble</span>
    <% end %>

    <div class="sb-section">Contenus</div>
    <%= link_to platform_admin_supports_path, class: "nav-item #{request.path.start_with?('/plateforme/admin/supports') ? 'active' : ''}" do %>
      <svg class="ni" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 1h6l4 4v10H4V1z"/><path d="M10 1v4h4"/><path d="M6 8h4M6 11h4"/></svg>
      <span>Supports de cours</span>
      <span class="nb"><%= CoursSupport.count %></span>
    <% end %>
    <%= link_to platform_admin_generateur_path, class: "nav-item #{request.path.start_with?('/plateforme/admin/generateur') ? 'active' : ''}" do %>
      <svg class="ni" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="8 1 10 6 15 6 11 10 13 15 8 12 3 15 5 10 1 6 6 6"/></svg>
      <span>Générateur IA</span>
    <% end %>

    <div class="sb-section">Apprenants</div>
    <%= link_to platform_admin_eleves_path, class: "nav-item #{request.path.start_with?('/plateforme/admin/eleves') ? 'active' : ''}" do %>
      <svg class="ni" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="6" cy="5" r="2.5"/><path d="M1 13c0-2.76 2.24-5 5-5s5 2.24 5 5"/><circle cx="12" cy="5" r="2"/><path d="M11.5 10c1.66.42 3 1.66 3 3.5"/></svg>
      <span>Élèves</span>
      <span class="nb"><%= User.where(role: "eleve").count %></span>
    <% end %>

  <% else %>
    <%# ─── MENU ÉLÈVE ─── %>
    <div class="sb-section">Mon espace</div>
    <%= link_to platform_catalogue_path, class: "nav-item #{request.path == '/plateforme/catalogue' ? 'active' : ''}" do %>
      <svg class="ni" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 4h12M2 8h12M2 12h7"/><circle cx="13" cy="12" r="2"/></svg>
      <span>Catalogue</span>
    <% end %>
    <%= link_to platform_mes_formations_path, class: "nav-item #{request.path == '/plateforme/mes-formations' ? 'active' : ''}" do %>
      <svg class="ni" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 1L14 4.5V11L8 14.5L2 11V4.5L8 1z"/></svg>
      <span>Mes formations</span>
      <% nb = current_user.inscriptions.count %>
      <% if nb > 0 %><span class="nb"><%= nb %></span><% end %>
    <% end %>
    <%= link_to platform_profil_path, class: "nav-item #{request.path == '/plateforme/profil' ? 'active' : ''}" do %>
      <svg class="ni" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="8" cy="5" r="3"/><path d="M2 14c0-3.31 2.69-6 6-6s6 2.69 6 6"/></svg>
      <span>Mon profil</span>
    <% end %>
  <% end %>

  <div class="sb-exit">
    <div class="sb-avatar"><%= current_user&.nom_complet&.upcase&.first(2) || current_user&.email&.first(2)&.upcase || "??" %></div>
    <div>
      <div class="sb-user-name"><%= current_user&.nom_complet %></div>
      <div class="sb-user-role"><%= current_user&.admin? ? "Administrateur" : "Apprenant" %></div>
    </div>
    <%= link_to root_path, class: "sb-exit-icon", title: "Retour au site" do %>⇤<% end %>
  </div>
</nav>
