<% content_for :page_title do %>Messagerie<% end %>

<div class="mwrap">
  <!-- Liste conversations -->
  <div class="mlist">
    <div style="padding:16px 16px 10px;border-bottom:1px solid var(--border);">
      <div style="font-size:11px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--ink-60);">Conversations</div>
    </div>
    <% @conversations.each do |conv| %>
      <div class="mconv <%= 'active' if conv[:active] %>">
        <div class="ava" style="width:38px;height:38px;border-radius:50%;background:<%= conv[:couleur] %>;font-size:13px;flex-shrink:0;"><%= conv[:initiales] %></div>
        <div style="flex:1;min-width:0;">
          <div style="display:flex;justify-content:space-between;margin-bottom:2px;">
            <span style="font-size:13px;font-weight:600;color:var(--ink);"><%= conv[:nom] %></span>
            <span style="font-size:10px;color:var(--ink-60);"><%= conv[:heure] %></span>
          </div>
          <div style="font-size:11px;color:var(--ink-60);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= conv[:role] %></div>
          <div style="font-size:11px;color:var(--ink-60);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= conv[:extrait] %></div>
        </div>
        <% if conv[:non_lus]&.positive? %>
          <div style="width:18px;height:18px;background:var(--accent);border-radius:50%;font-size:9px;font-weight:700;color:#fff;display:flex;align-items:center;justify-content:center;flex-shrink:0;"><%= conv[:non_lus] %></div>
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- Fenêtre principale -->
  <div class="mmain">
    <div class="mmain-header">
      <div class="row">
        <div class="ava" style="width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,#1c5fff,#6366f1);font-size:13px;">SR</div>
        <div>
          <div style="font-weight:600;font-size:14px;">Sophie Renard</div>
          <div style="font-size:11px;color:var(--green);">● En ligne</div>
        </div>
      </div>
    </div>

    <div class="mmain-body">
      <% @messages_actifs.each do |msg| %>
        <div class="msg-row <%= msg[:role] %>">
          <% if msg[:role] == :them %>
            <div class="ava" style="width:28px;height:28px;border-radius:50%;background:linear-gradient(135deg,#1c5fff,#6366f1);font-size:10px;flex-shrink:0;">SR</div>
          <% end %>
          <div class="msg-bubble <%= msg[:role] %>">
            <%= msg[:texte] %>
            <div style="font-size:9px;margin-top:4px;opacity:.55;text-align:right;"><%= msg[:heure] %></div>
          </div>
        </div>
      <% end %>
    </div>

    <div class="mmain-footer">
      <input type="text" placeholder="Votre message…" class="msg-input">
      <button class="btn ba bs" style="padding:10px 18px;">↑</button>
    </div>
  </div>
</div>
