<div class="platform-page">
  <div class="topbar">
    <div class="topbar-left">
      <h1 class="page-title">Générateur IA</h1>
      <p class="page-sub">Générez des modules et quiz à partir de vos supports</p>
    </div>
    <%= link_to platform_admin_new_support_path, class: "btn bp" do %>
      + Nouveau support
    <% end %>
  </div>

  <% if @supports.any? %>
    <div class="gen-grid">
      <% @supports.each do |s| %>
        <div class="gen-card">
          <div class="gen-card-head">
            <div>
              <h3 class="gen-card-title"><%= link_to s.titre, platform_admin_support_path(s) %></h3>
              <div class="gen-card-meta"><%= s.module_formations.count %> module(s) · <%= s.statut %></div>
            </div>
            <span class="status-badge status-<%= s.statut %>"></span>
          </div>
          <% if s.contenu_texte.blank? && !s.fichier.attached? %>
            <div class="gen-warning">⚠️ Ajoutez du contenu texte pour pouvoir générer des modules.</div>
          <% else %>
            <%# ── Modules IA ── %>
            <div
              data-controller="generateur-module"
              data-generateur-module-modules-url-value="<%= generer_modules_platform_admin_support_path(s) %>"
              data-generateur-module-support-id-value="<%= s.id %>">
              <div class="gen-controls">
                <label>Modules</label>
                <select data-generateur-module-target="nbModules" class="form-control" style="width:70px;">
                  <option>2</option><option selected>3</option><option>4</option><option>5</option>
                </select>
                <button class="btn bp btn-sm" data-action="click->generateur-module#generer">
                  ✨ Générer modules
                </button>
              </div>
              <div data-generateur-module-target="status" style="display:none;margin-top:8px;font-size:12px;color:var(--ink-60);"></div>
              <div data-generateur-module-target="results"></div>
            </div>

            <%# ── Slides IA ── %>
            <%= form_with url: generer_slides_platform_admin_support_path(s), method: :post,
                          data: { turbo: false },
                          class: "gen-controls", style: "margin-top:10px;" do |f| %>
              <label>Slides</label>
              <%= f.select :nb_slides,
                    options_for_select([[8,8],[10,10],[12,12],[15,15],[20,20]], 12),
                    {}, class: "form-control", style: "width:70px;" %>
              <%= f.submit "🎞 Générer slides", class: "btn btn-outline-secondary btn-sm" %>
            <% end %>

            <%# Lien preview si slides existantes %>
            <% if s.programme_json&.key?("slides") %>
              <div style="margin-top:8px;">
                <%= link_to "👁 Voir les #{s.programme_json['slides'].size} slides",
                      slides_preview_platform_admin_support_path(s),
                      class: "btn bp btn-sm" %>
              </div>
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state">
      <div class="es-icon">✨</div>
      <h3>Aucun support disponible</h3>
      <p>Créez d'abord un support de cours pour pouvoir générer des modules.</p>
      <%= link_to "Créer un support", platform_admin_new_support_path, class: "btn bp" %>
    </div>
  <% end %>
</div>
