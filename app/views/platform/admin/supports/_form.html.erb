<%= form_with model: [:platform, :admin, support], class: "lms-form" do |f| %>
  <% if support.errors.any? %>
    <div class="form-errors">
      <% support.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div class="form-group">
    <%= f.label :titre, "Titre du support" %>
    <%= f.text_field :titre, placeholder: "Ex : Management et Leadership", class: "form-control" %>
  </div>

  <div class="form-group">
    <%= f.label :description, "Description (courte)" %>
    <%= f.text_area :description, rows: 3, placeholder: "Décrivez brièvement ce support…", class: "form-control" %>
  </div>

  <div class="form-group">
    <%= f.label :contenu_texte, "Contenu textuel (base de génération IA)" %>
    <%= f.text_area :contenu_texte, rows: 12, placeholder: "Collez ici votre contenu de cours, vos notes, vos slides textuelles…\nL'IA s'en servira pour générer les modules.", class: "form-control" %>
  </div>

  <div class="form-group">
    <%= f.label :fichier, "Ou importer un fichier (PDF, DOCX, TXT)" %>
    <%= f.file_field :fichier, class: "form-control", accept: ".pdf,.docx,.txt" %>
    <% if support.fichier.attached? %>
      <p class="form-hint">Fichier actuel : <%= support.fichier.filename %></p>
    <% end %>
  </div>

  <div class="form-actions">
    <%= f.submit support.new_record? ? "Créer le support" : "Mettre à jour", class: "btn bp" %>
    <%= link_to "Annuler", support.new_record? ? platform_admin_supports_path : platform_admin_support_path(support), class: "btn" %>
  </div>
<% end %>
