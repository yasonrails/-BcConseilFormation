<%#
  Renders a styled list of pedagogical objectives.

  Locals:
    objectifs (Array<String>) — list of objectives
    label     (String)        — section label (default: "Objectifs pédagogiques")
    wrapper   (Boolean)       — wrap in a .card element (default: true)
%>
<% label     = local_assigns.fetch(:label,   "Objectifs pédagogiques") %>
<% wrapper   = local_assigns.fetch(:wrapper, true) %>
<% inner_html = capture do %>
  <p class="lbl" style="margin-bottom:8px"><%= label %></p>
  <ul class="mc-obj-list">
    <% objectifs.each do |obj| %>
      <li><%= obj %></li>
    <% end %>
  </ul>
<% end %>

<% if wrapper %>
  <div class="card cp" style="margin-bottom:14px"><%= inner_html %></div>
<% else %>
  <div class="mc-objectifs cp" style="border-top:1px solid var(--ink-10);padding-top:14px">
    <%= inner_html %>
  </div>
<% end %>
