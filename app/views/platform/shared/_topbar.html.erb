<%#
  Reusable platform topbar.

  Locals:
    title      (String)  — main title text
    subtitle   (String)  — wrapped in <em>, optional
    back_path  (String)  — href for back button, optional
    back_label (String)  — back button text (default: "← Retour")
    # yield :topbar_right for custom right-side buttons / content
%>
<div class="topbar">
  <% full_title = subtitle.present? ? safe_join([title.to_s, content_tag(:em, subtitle)], " ") : title.to_s %>
  <h1 class="topbar-title"><%= full_title.html_safe %></h1>

  <div class="row">
    <%= content_for(:topbar_right) { "" } %>
    <%= yield if block_given? %>

    <% if local_assigns[:back_path].present? %>
      <%= link_to back_path, class: "btn bo bs" do %>
        <%= local_assigns.fetch(:back_label, "← Retour") %>
      <% end %>
    <% end %>
  </div>
</div>
