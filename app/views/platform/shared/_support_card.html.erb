<%#
  Support card — used in supports/index and generateur/index.

  Locals:
    support  (CoursSupport) — the record to display
    variant  (Symbol)       — :full (default, with all actions) | :ready (generateur view)
%>
<% variant = local_assigns.fetch(:variant, :full) %>
<div class="support-card<%= variant == :ready ? ' support-card--ready' : '' %>">
  <% if variant == :ready %>
    <div class="sc-ready-badge">✓ Prêt</div>
  <% else %>
    <div class="sc-header">
      <div class="sc-icon">📄</div>
      <div class="sc-meta"><%= statut_tag(support) %></div>
    </div>
  <% end %>

  <h3 class="sc-title"><%= support.titre %></h3>

  <p class="sc-desc">
    <% if variant == :ready %>
      <%= truncate(support.contenu_texte.to_s.gsub(/\s+/, " "), length: 120) %>
    <% else %>
      <%= support.description.presence || "Aucune description" %>
    <% end %>
  </p>

  <div class="sc-stats">
    <span class="sc-stat">
      <strong><%= support.modules_count %></strong> <%= support.modules_count == 1 ? "module" : "modules" %>
    </span>
    <% if variant == :full %>
      <span class="sc-stat"><%= support.created_at.strftime("%d/%m/%Y") %></span>
    <% end %>
  </div>

  <% if variant == :ready %>
    <%= link_to platform_support_path(support), class: "btn-gen-ia" do %>
      <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
      </svg>
      Générer des modules
    <% end %>
  <% else %>
    <div class="sc-actions">
      <%= link_to platform_support_path(support),      class: "btn bo bs" do %>Voir<% end %>
      <%= link_to platform_edit_support_path(support), class: "btn bo bs" do %>Modifier<% end %>
      <%= button_to platform_support_path(support), method: :delete,
            data: { turbo_confirm: "Supprimer ce support et tous ses modules ?" },
            class: "btn bs",
            style: "background:transparent;color:var(--red);border:1px solid var(--red-bg)" do %>
        Supprimer
      <% end %>
    </div>
  <% end %>
</div>
