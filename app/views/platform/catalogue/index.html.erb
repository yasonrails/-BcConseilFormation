<% content_for :page_title do %>Catalogue <em>formations</em><% end %>

<div style="margin-bottom:18px;" class="rb">
  <div>
    <div class="lbl" style="margin-bottom:4px;">Nos formations</div>
    <h1 style="font-family:var(--serif);font-size:32px;font-weight:300;letter-spacing:-.02em;">Catalogue <em style="font-style:italic;color:var(--ink-60)">complet</em></h1>
  </div>
  <span class="bxs"><%= @formations.size %> formations disponibles</span>
</div>

<div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:18px;">
  <button class="btn bo bs" style="background:var(--ink);color:#fff;border-color:var(--ink);">Tout</button>
  <% %w[Ressources\ Humaines Droit\ du\ Travail Management Audit PCRH].each do |cat| %>
    <button class="btn bo bs"><%= cat %></button>
  <% end %>
</div>

<div class="g3">
  <% @formations.each do |f| %>
    <div class="cc">
      <div class="cb" style="background:<%= f[:couleur] %>"><%= f[:category] %></div>
      <div class="cbody">
        <div class="ct"><%= f[:title] %></div>
        <div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:10px;">
          <span class="tag <%= f[:badge_class] %>"><%= f[:category] %></span>
          <span class="tag tgr"><%= f[:modules] %> modules</span>
          <span class="tag tgr"><%= f[:heures] %>h</span>
        </div>
        <div class="cfooter">
          <% if f[:financement] %>
            <div style="font-size:13px;color:var(--green);font-weight:600;">Financement État</div>
            <button class="btn ba bs">Éligibilité</button>
          <% else %>
            <div class="cp2"><%= f[:prix] %> € <span style="font-size:11px;font-weight:400;color:var(--ink-60)">HT</span></div>
            <%= link_to "S'inscrire", platform_formation_path, class: "btn bp bs" %>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <div class="cc" style="background:var(--sand);display:flex;align-items:center;justify-content:center;min-height:200px;flex-direction:column;gap:10px;border:2px dashed var(--ink-10);">
    <div style="font-size:28px;opacity:.25">+</div>
    <div class="bxs">Prochainement</div>
  </div>
</div>
