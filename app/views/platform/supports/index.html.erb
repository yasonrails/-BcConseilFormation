<%# app/views/platform/supports/index.html.erb %>
<% content_for :title, "Supports de cours" %>

<div class="topbar">
  <h1 class="topbar-title">Supports <em>de cours</em></h1>
  <%= link_to platform_new_support_path, class: "btn bp" do %>
    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg>
    Nouveau support
  <% end %>
  <%= link_to platform_generateur_path, class: "btn bo" do %>
    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
    Générateur IA
  <% end %>
</div>

<div class="vp">
  <% if @supports.empty? %>
    <div class="gen-empty">
      <div class="gen-empty-icon">📄</div>
      <h3>Aucun support de cours</h3>
      <p>Uploadez un PDF, DOCX ou saisissez votre contenu directement pour commencer à générer des modules de formation.</p>
      <%= link_to "Créer mon premier support", platform_new_support_path, class: "btn bp" %>
    </div>
  <% else %>
    <div class="supports-grid">
      <% @supports.each do |support| %>
        <div class="support-card">
          <div class="sc-header">
            <div class="sc-icon">📄</div>
            <div class="sc-meta">
              <span class="tag <%= support.pret? ? 'tg' : 'tgr' %>">
                <%= support.pret? ? "✓ Prêt" : "Brouillon" %>
              </span>
            </div>
          </div>
          <h3 class="sc-title"><%= support.titre %></h3>
          <p class="sc-desc"><%= support.description.presence || "Aucune description" %></p>
          <div class="sc-stats">
            <span class="sc-stat">
              <strong><%= support.modules_count %></strong> module<%= "s" if support.modules_count != 1 %>
            </span>
            <span class="sc-stat"><%= support.created_at.strftime("%d/%m/%Y") %></span>
          </div>
          <div class="sc-actions">
            <%= link_to platform_support_path(support), class: "btn bo bs" do %>
              Voir
            <% end %>
            <%= link_to platform_edit_support_path(support), class: "btn bo bs" do %>
              Modifier
            <% end %>
            <%= button_to platform_support_path(support), method: :delete,
                          data: { turbo_confirm: "Supprimer ce support et tous ses modules ?" },
                          class: "btn bs", style: "background:transparent;color:var(--red);border:1px solid var(--red-bg)" do %>
              Supprimer
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
