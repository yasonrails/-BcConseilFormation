<%# app/views/platform/supports/_form.html.erb %>
<%= form_with model: [:platform, support], html: { class: "support-form", multipart: true } do |f| %>
  <% if support.errors.any? %>
    <div class="gen-error" style="display:block;margin-bottom:16px">
      <% support.errors.full_messages.each do |msg| %>
        <p>• <%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div class="form-field">
    <%= f.label :titre, "Titre du support", class: "gen-label" %>
    <%= f.text_field :titre, class: "gen-input", placeholder: "Ex. : Droit du travail — Module socle" %>
  </div>

  <div class="form-field">
    <%= f.label :description, "Description (optionnelle)", class: "gen-label" %>
    <%= f.text_area :description, class: "gen-input", rows: 2,
                    placeholder: "À qui s'adresse ce support ? Quel niveau ?" %>
  </div>

  <div class="form-field">
    <%= f.label :fichier, "Fichier source (PDF, DOCX, TXT)", class: "gen-label" %>
    <div class="file-drop-zone" data-controller="file-drop"
         data-file-drop-accept-value=".pdf,.docx,.txt">
      <input type="file" name="cours_support[fichier]" id="cours_support_fichier"
             class="file-input" accept=".pdf,.docx,.txt"
             data-action="change->file-drop#preview">
      <label for="cours_support_fichier" class="file-drop-label">
        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
        </svg>
        <span data-file-drop-target="label">Cliquer ou glisser-déposer un fichier</span>
        <span class="file-drop-hint">PDF, DOCX ou TXT — max 10 Mo</span>
      </label>
    </div>
  </div>

  <div class="form-field">
    <%= f.label :contenu_texte, "Contenu textuel", class: "gen-label" %>
    <p class="gen-hint">Saisissez ou collez votre contenu ici. S'il y a un fichier, le texte sera extrait automatiquement.</p>
    <%= f.text_area :contenu_texte, class: "gen-input gen-textarea", rows: 12,
                    placeholder: "Collez ici le contenu de votre support de cours…" %>
  </div>

  <div class="form-field">
    <%= f.label :statut, "Statut", class: "gen-label" %>
    <div class="gen-statut-selector">
      <label class="statut-opt">
        <%= f.radio_button :statut, "brouillon" %>
        <span>Brouillon</span>
      </label>
      <label class="statut-opt">
        <%= f.radio_button :statut, "pret" %>
        <span>Prêt à utiliser</span>
      </label>
    </div>
  </div>

  <div class="form-actions">
    <%= f.submit support.new_record? ? "Créer le support" : "Mettre à jour", class: "btn bp" %>
    <%= link_to "Annuler", support.new_record? ? platform_supports_path : platform_support_path(support),
                class: "btn bo" %>
  </div>
<% end %>
