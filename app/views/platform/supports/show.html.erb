<%# app/views/platform/supports/show.html.erb %>
<% content_for :title, @support.titre %>

<div class="topbar">
  <h1 class="topbar-title"><%= @support.titre %></h1>
  <div class="row">
    <span class="tag <%= @support.pret? ? 'tg' : 'tgr' %>">
      <%= @support.pret? ? "✓ Prêt" : "Brouillon" %>
    </span>
    <%= link_to platform_edit_support_path(@support), class: "btn bo bs" do %>
      Modifier
    <% end %>
    <%= link_to platform_supports_path, class: "btn bo bs" do %>
      ← Supports
    <% end %>
  </div>
</div>

<div class="vp" data-controller="generateur"
     data-generateur-modules-url-value="<%= generer_modules_platform_support_path(@support) %>"
     data-generateur-support-id-value="<%= @support.id %>">

  <%# ─── Bloc génération IA ─── %>
  <div class="gen-panel card cp" data-generateur-target="panel">
    <div class="gen-panel-header">
      <div class="gen-panel-icon">
        <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
        </svg>
      </div>
      <div>
        <h2 class="gen-panel-title">Générer des modules avec l'IA</h2>
        <p class="gen-panel-sub">L'IA analyse votre support et génère automatiquement des modules structurés avec objectifs et quiz.</p>
      </div>
    </div>

    <div class="gen-options">
      <label class="gen-label">Nombre de modules à générer</label>
      <div class="gen-nb-selector" data-generateur-target="nbSelector">
        <% [1, 2, 3, 4, 5].each do |n| %>
          <button type="button" class="gen-nb-btn <%= n == 3 ? 'active' : '' %>"
                  data-action="click->generateur#selectNb"
                  data-nb="<%= n %>"><%= n %></button>
        <% end %>
      </div>
    </div>

    <button type="button" class="btn-gen-ia" data-action="click->generateur#genererModules"
            data-generateur-target="genBtn"
            <%= @support.pret? ? '' : 'disabled' %>>
      <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
      </svg>
      <span data-generateur-target="genBtnLabel">Générer les modules</span>
    </button>

    <% unless @support.pret? %>
      <p class="gen-warn">⚠️ Ajoutez du contenu texte à ce support pour activer la génération.</p>
    <% end %>

    <%# États de chargement et résultats %>
    <div class="gen-loading" data-generateur-target="loading" style="display:none">
      <div class="gen-loading-bar"><div class="gen-loading-fill"></div></div>
      <p class="gen-loading-text" data-generateur-target="loadingText">Analyse du support en cours…</p>
    </div>

    <div class="gen-results" data-generateur-target="results" style="display:none">
      <div class="gen-results-header">
        <h3 class="gen-results-title" data-generateur-target="resultsTitle"></h3>
      </div>
      <div class="gen-modules-list" data-generateur-target="modulesList"></div>
    </div>

    <div class="gen-error" data-generateur-target="error" style="display:none">
      <span data-generateur-target="errorMsg"></span>
    </div>
  </div>

  <%# ─── Modules existants ─── %>
  <% if @modules.any? %>
    <div class="gen-section-title">
      <h2>Modules générés <span class="gen-count"><%= @modules.count %></span></h2>
    </div>

    <div class="modules-list">
      <% @modules.each_with_index do |mod, idx| %>
        <div class="module-card card" data-controller="generateur-module"
             data-generateur-module-quiz-url-value="<%= generer_quiz_platform_support_module_path(@support, mod) %>">
          <div class="module-card-header cp">
            <div class="mc-left">
              <span class="mc-num">Module <%= sprintf("%02d", idx + 1) %></span>
              <h3 class="mc-title"><%= mod.titre %></h3>
              <div class="mc-meta row">
                <% if mod.duree_estimee.present? %>
                  <span class="tag tgr">⏱ <%= mod.duree_estimee %></span>
                <% end %>
                <span class="tag <%= mod.publie? ? 'tg' : 'tgr' %>">
                  <%= mod.publie? ? "✓ Publié" : "Brouillon" %>
                </span>
                <span class="bxs"><%= mod.quiz_questions.count %> question<%= "s" if mod.quiz_questions.count != 1 %> quiz</span>
              </div>
            </div>
            <div class="mc-actions row">
              <button type="button" class="btn bo bs" data-action="click->generateur-module#genererQuiz"
                      data-generateur-module-target="quizBtn">
                ⚡ Quiz IA
              </button>
              <%= link_to platform_support_module_path(@support, mod), class: "btn bo bs" do %>
                Voir
              <% end %>
            </div>
          </div>

          <% if mod.objectifs_list.any? %>
            <div class="mc-objectifs cp" style="border-top:1px solid var(--ink-10);padding-top:14px">
              <p class="lbl" style="margin-bottom:8px">Objectifs pédagogiques</p>
              <ul class="mc-obj-list">
                <% mod.objectifs_list.each do |obj| %>
                  <li><%= obj %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <div class="gen-quiz-loading" data-generateur-module-target="loading" style="display:none">
            <div class="gen-loading-bar"><div class="gen-loading-fill"></div></div>
            <p class="gen-loading-text">Génération du quiz en cours…</p>
          </div>

          <div class="gen-quiz-result" data-generateur-module-target="quizResult" style="display:none">
            <p class="gen-success-msg" data-generateur-module-target="quizMsg"></p>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="gen-empty-modules">
      <p>Aucun module généré pour ce support. Utilisez le bouton ci-dessus pour en créer.</p>
    </div>
  <% end %>
</div>
