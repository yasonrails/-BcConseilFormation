<%# app/views/platform/modules/show.html.erb %>
<% content_for :title, @module.titre %>

<div class="topbar">
  <h1 class="topbar-title"><%= @module.titre %></h1>
  <div class="row">
    <span class="tag <%= @module.publie? ? 'tg' : 'tgr' %>">
      <%= @module.publie? ? "✓ Publié" : "Brouillon" %>
    </span>
    <%= link_to platform_edit_support_module_path(@support, @module), class: "btn bo bs" do %>
      Modifier
    <% end %>
    <%= link_to platform_support_path(@support), class: "btn bo bs" do %>
      ← Support
    <% end %>
  </div>
</div>

<div class="vp">
  <div class="g2" style="align-items:start">

    <%# ─── Contenu principal ─── %>
    <div style="grid-column:1">

      <%# Objectifs %>
      <% if @module.objectifs_list.any? %>
        <div class="card cp" style="margin-bottom:14px">
          <p class="lbl" style="margin-bottom:12px">🎯 Objectifs pédagogiques</p>
          <ul class="mc-obj-list">
            <% @module.objectifs_list.each do |obj| %>
              <li><%= obj %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%# Contenu HTML %>
      <% if @module.contenu.present? %>
        <div class="card cp module-contenu">
          <p class="lbl" style="margin-bottom:16px">📖 Contenu du module</p>
          <div class="module-html-content"><%= @module.contenu.html_safe %></div>
        </div>
      <% end %>
    </div>

    <%# ─── Sidebar Quiz ─── %>
    <div style="grid-column:2">
      <div class="card cp" style="position:sticky;top:72px">
        <div class="rb" style="margin-bottom:16px">
          <p class="lbl">❓ Quiz</p>
          <span class="tag tb"><%= @module.quiz_questions.count %> question<%= "s" if @module.quiz_questions.count != 1 %></span>
        </div>

        <% if @module.quiz_questions.any? %>
          <div class="quiz-preview" data-controller="quiz-player">
            <% @module.quiz_questions.ordonnes.each_with_index do |q, idx| %>
              <div class="quiz-q-item" data-quiz-player-target="question"
                   data-correct="<%= q.bonne_reponse %>" style="<%= idx == 0 ? '' : 'display:none' %>">
                <p class="quiz-q-num">Q<%= idx + 1 %> / <%= @module.quiz_questions.count %></p>
                <p class="quiz-q-enonce"><%= q.enonce %></p>
                <div class="quiz-opts">
                  <% q.options_list.each_with_index do |opt, i| %>
                    <button class="quiz-opt" data-action="click->quiz-player#answer" data-index="<%= i %>">
                      <span class="quiz-opt-letter"><%= ("A".ord + i).chr %></span>
                      <%= opt %>
                    </button>
                  <% end %>
                </div>
                <div class="quiz-feedback" data-quiz-player-target="feedback" style="display:none">
                  <p class="quiz-feedback-text" data-quiz-player-target="feedbackText"></p>
                  <p class="quiz-explication"><%= q.explication %></p>
                  <% if idx < @module.quiz_questions.count - 1 %>
                    <button class="btn bp bs" data-action="click->quiz-player#next">Suivant →</button>
                  <% else %>
                    <button class="btn bp bs" data-action="click->quiz-player#finish">Terminer le quiz ✓</button>
                  <% end %>
                </div>
              </div>
            <% end %>
            <div class="quiz-score" data-quiz-player-target="score" style="display:none">
              <p class="quiz-score-val" data-quiz-player-target="scoreVal"></p>
              <p class="quiz-score-lbl">réponses correctes</p>
              <button class="btn bo bs" data-action="click->quiz-player#restart">Recommencer</button>
            </div>
          </div>
        <% else %>
          <p class="bxs">Aucune question. Utilisez ⚡ Quiz IA sur la page du support pour en générer.</p>
        <% end %>
      </div>
    </div>

  </div>
</div>
