<%# app/views/platform/modules/edit.html.erb %>
<% content_for :title, "Modifier — #{@module.titre}" %>

<div class="topbar">
  <h1 class="topbar-title">Modifier <em><%= truncate(@module.titre, length: 40) %></em></h1>
  <%= link_to platform_support_module_path(@support, @module), class: "btn bo bs" do %>
    ← Module
  <% end %>
</div>

<div class="vp">
  <div class="card cp gen-form-wrap">
    <%= form_with model: [:platform, @support, @module], html: { class: "support-form" } do |f| %>
      <% if @module.errors.any? %>
        <div class="gen-error" style="display:block;margin-bottom:16px">
          <% @module.errors.full_messages.each do |msg| %>
            <p>• <%= msg %></p>
          <% end %>
        </div>
      <% end %>

      <div class="form-field">
        <%= f.label :titre, "Titre du module", class: "gen-label" %>
        <%= f.text_field :titre, class: "gen-input" %>
      </div>

      <div class="form-field">
        <%= f.label :duree_estimee, "Durée estimée", class: "gen-label" %>
        <%= f.text_field :duree_estimee, class: "gen-input", placeholder: "Ex. : 1h30" %>
      </div>

      <div class="form-field">
        <%= f.label :contenu, "Contenu du module", class: "gen-label" %>
        <p class="gen-hint">HTML simple accepté (&lt;p&gt;, &lt;h3&gt;, &lt;ul&gt;, &lt;strong&gt;)</p>
        <%= f.text_area :contenu, class: "gen-input gen-textarea", rows: 14 %>
      </div>

      <div class="form-field">
        <%= f.label :statut, "Statut", class: "gen-label" %>
        <div class="gen-statut-selector">
          <label class="statut-opt"><%= f.radio_button :statut, "brouillon" %> <span>Brouillon</span></label>
          <label class="statut-opt"><%= f.radio_button :statut, "publie" %> <span>Publié</span></label>
        </div>
      </div>

      <div class="form-actions">
        <%= f.submit "Mettre à jour", class: "btn bp" %>
        <%= link_to "Annuler", platform_support_module_path(@support, @module), class: "btn bo" %>
      </div>
    <% end %>
  </div>
</div>
