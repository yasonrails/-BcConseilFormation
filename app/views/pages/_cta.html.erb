    </div>
    <div class="pcc-right">
      <button class="btn-platform" data-action="home#openLogin">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8">
          <path d="M8 1L14 4.5V11L8 14.5L2 11V4.5L8 1z"/>
        </svg>
        Accéder à mon espace
      </button>
      <p class="pcc-note">Formation · Suivi · Certification</p>
    </div>
  </div>
</div>
