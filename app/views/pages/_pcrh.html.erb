<%# ══════════════════════════════════════════════
    PCRH — Prestation de Conseil en RH
══════════════════════════════════════════════ %>
<section class="pcrh-full" id="pcrh">

  <%# ── Hero intro ── %>
  <div class="pcrh-hero">
    <div class="pcrh-hero-content">
      <span class="pcrh-tag reveal">Dispositif d'État · Financement jusqu'à 100%</span>
      <h2 class="pcrh-title reveal">
        Prestation de Conseil<br>en <em>Ressources Humaines</em>
      </h2>
      <p class="pcrh-p reveal">
        La PCRH a été mise en place pour les dirigeants de PME/TPE ou de start-up qui souhaitent améliorer la gestion de leurs ressources humaines mais qui n'ont pas les ressources ou le temps nécessaire pour s'en occuper.
      </p>
      <p class="pcrh-p reveal">
        La PCRH permet aux entreprises de <strong>moins de 250 salariés</strong> de bénéficier d'un accompagnement RH réalisé par un prestataire spécialisé — financé par votre OPCO et la DREETS <strong>jusqu'à 100%</strong>.
      </p>
      <a href="#contact" class="btn-dark reveal">Vérifier mon éligibilité →</a>
    </div>
    <div class="pcrh-hero-visual reveal">
      <div class="pcrh-frame">
        <div class="pcrh-frame-bg"></div>
        <div class="pcrh-frame-img">
          <img src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?w=700&q=80"
               alt="Deux professionnels collaborant autour d'un ordinateur portable dans un bureau moderne"
               loading="lazy">
        </div>
        <div class="pcrh-frame-caption">Accompagnement RH sur-mesure</div>
      </div>
      <div class="pcrh-accent"></div>
    </div>
  </div>

  <%# ── Principes généraux ── %>
  <div class="pcrh-block pcrh-block--sand">
    <div class="pcrh-block-inner">
      <div class="pcrh-block-hd">
        <span class="pcrh-section-label">Principes généraux</span>
        <h3 class="pcrh-block-title">La PCRH va vous permettre<br>de mettre en œuvre</h3>
      </div>
      <ul class="pcrh-pills-list">
        <li>Une organisation clarifiée</li>
        <li>Des pratiques managériales structurées</li>
        <li>Un process de recrutement</li>
        <li>Une procédure d'intégration</li>
        <li>Des ressources adaptées à vos besoins</li>
        <li>Une politique de qualité de vie au travail</li>
        <li>Une meilleure répartition de la charge de travail</li>
        <li>Des pratiques RH conformes à la réglementation du travail</li>
      </ul>
    </div>
  </div>

  <%# ── Objectifs ── %>
  <div class="pcrh-block">
    <div class="pcrh-block-inner pcrh-two-col">
      <div>
        <span class="pcrh-section-label">Objectifs de la PCRH</span>
        <h3 class="pcrh-block-title">Une démarche en trois temps</h3>
      </div>
      <ol class="pcrh-obj-list">
        <li>
          <span class="pcrh-obj-num">01</span>
          <div>
            <strong>Diagnostic RH</strong>
            <p>Réaliser un diagnostic RH de votre entreprise et identifier les besoins d'accompagnement.</p>
          </div>
        </li>
        <li>
          <span class="pcrh-obj-num">02</span>
          <div>
            <strong>Co-construction</strong>
            <p>Co-construire des outils et un plan d'action partagé par les acteurs de l'entreprise.</p>
          </div>
        </li>
        <li>
          <span class="pcrh-obj-num">03</span>
          <div>
            <strong>Autonomie</strong>
            <p>Accompagner la mise en œuvre des actions en rendant votre entreprise autonome et en lui permettant l'appropriation des outils.</p>
          </div>
        </li>
      </ol>
    </div>
  </div>

  <%# ── Déroulement ── %>
  <div class="pcrh-block pcrh-block--sand">
    <div class="pcrh-block-inner">
      <span class="pcrh-section-label">Déroulement</span>
      <h3 class="pcrh-block-title">Comment se déroule la prestation ?</h3>
      <div class="pcrh-phases">
        <div class="pcrh-phase">
          <div class="pcrh-phase-hd">
            <span class="pcrh-phase-num">Phase 1</span>
            <h4 class="pcrh-phase-title">Cadrage & validation</h4>
          </div>
          <ul class="pcrh-phase-steps">
            <li>Définition des besoins RH de votre société</li>
            <li>Évaluation de la durée de la prestation (taille de l'entreprise, définition du besoin, étude en lien avec votre OPCO)</li>
            <li>Présentation du projet à votre OPCO via une fiche projet détaillée</li>
            <li>Validation de la prise en charge par l'OPCO</li>
          </ul>
        </div>
        <div class="pcrh-phase-divider">→</div>
        <div class="pcrh-phase">
          <div class="pcrh-phase-hd">
            <span class="pcrh-phase-num">Phase 2</span>
            <h4 class="pcrh-phase-title">Déploiement & restitution</h4>
          </div>
          <ul class="pcrh-phase-steps">
            <li>Élaboration du planning de la prestation</li>
            <li>Déroulement du plan d'action</li>
            <li>RDV de restitution (OPCO / entreprise / BC Conseil Formation)</li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <%# ── 8 thématiques ── %>
  <div class="pcrh-block">
    <div class="pcrh-block-inner">
      <span class="pcrh-section-label">Les 8 thématiques</span>
      <h3 class="pcrh-block-title">Les domaines dans lesquels<br>notre équipe vous accompagne</h3>
      <div class="pcrh-themes-grid">
        <% [
          { num: "01", title: "Talents & compétences", desc: "Stratégie RH, plan de développement des compétences, mobilité professionnelle, plan de formation." },
          { num: "02", title: "Recrutement & attractivité", desc: "Stratégie, optimisation des outils et process, marque employeur." },
          { num: "03", title: "Mutations & transitions", desc: "Digitalisation, nouveaux outils RH, évolution des métiers, RSE." },
          { num: "04", title: "Variations d'activité", desc: "Gestion RH en situation de crise, enjeux RH liés à la réorganisation de l'activité." },
          { num: "05", title: "Organisation du travail", desc: "Télétravail, qualité de vie au travail, risques psycho-sociaux, turn-over." },
          { num: "06", title: "Dialogue social", desc: "Relations sociales, mise en place du CSE." },
          { num: "07", title: "Professionnalisation RH", desc: "Mise en place d'outils et de processus de gestion des ressources humaines." },
          { num: "08", title: "Intégration & inclusion", desc: "Processus d'intégration, inclusion et accompagnement des salariés." }
        ].each do |t| %>
          <div class="pcrh-theme-card reveal">
            <span class="pcrh-theme-num"><%= t[:num] %></span>
            <h4 class="pcrh-theme-title"><%= t[:title] %></h4>
            <p class="pcrh-theme-desc"><%= t[:desc] %></p>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <%# ── Éligibilité + Tarifs ── %>
  <div class="pcrh-block pcrh-block--ink">
    <div class="pcrh-block-inner pcrh-two-col pcrh-two-col--light">
      <div>
        <span class="pcrh-section-label pcrh-section-label--light">Critères d'éligibilité</span>
        <h3 class="pcrh-block-title pcrh-block-title--light">Qui peut en bénéficier ?</h3>
        <ul class="pcrh-eligib-list">
          <li>
            <span class="pcrh-eligib-icon">✓</span>
            <span>Toute entreprise ayant entre <strong>1 et 250 salariés</strong></span>
          </li>
          <li>
            <span class="pcrh-eligib-icon">✓</span>
            <span>Priorité aux entreprises de <strong>moins de 50 salariés</strong> et aux TPE de moins de 10 salariés sans service RH</span>
          </li>
          <li>
            <span class="pcrh-eligib-icon">✓</span>
            <span>Doit solliciter un <strong>prestataire externe spécialisé</strong> en gestion RH, tel que BC Conseil Formation</span>
          </li>
          <li>
            <span class="pcrh-eligib-icon">✓</span>
            <span>Intervention aboutissant à l'élaboration et la mise en œuvre d'un <strong>plan d'action RH</strong></span>
          </li>
        </ul>
      </div>
      <div>
        <span class="pcrh-section-label pcrh-section-label--light">Tarifs & financement</span>
        <h3 class="pcrh-block-title pcrh-block-title--light">Un coût neutre<br>pour votre entreprise</h3>
        <div class="pcrh-tarif-card">
          <div class="pcrh-tarif-pct">50%</div>
          <div class="pcrh-tarif-lbl">OPCO</div>
          <div class="pcrh-tarif-plus">+</div>
          <div class="pcrh-tarif-pct">50%</div>
          <div class="pcrh-tarif-lbl">DREETS</div>
        </div>
        <p class="pcrh-tarif-note">
          Le financement est partagé à parts égales entre l'OPCO et la DREETS — ce qui <strong>neutralise le coût pour votre entreprise</strong>. La gestion et le suivi sont assurés par la DREETS de chaque territoire.
        </p>
      </div>
    </div>
  </div>

  <%# ── Comment demander ── %>
  <div class="pcrh-cta-block">
    <div class="pcrh-cta-inner">
      <span class="pcrh-section-label">Comment demander cette aide ?</span>
      <h3 class="pcrh-cta-title">Prêt à structurer votre<br><em>fonction RH ?</em></h3>
      <p class="pcrh-cta-sub">Pour plus d'informations sur la prestation ou pour bénéficier d'un accompagnement, contactez dès à présent votre OPCO ou l'un de nos conseillers.</p>
      <div class="pcrh-cta-buttons">
        <a href="mailto:contact@bcconseilformation.fr" class="btn-dark">Contacter un conseiller →</a>
        <a href="#contact" class="btn-outline-dark">En savoir plus</a>
      </div>
    </div>
  </div>

</section>
