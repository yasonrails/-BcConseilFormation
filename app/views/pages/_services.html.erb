  <div class="expertise-list">
    <% expertise_items.each_with_index do |item, i| %>
      <div class="expertise-row <%= i.even? ? '' : 'expertise-row--reverse' %> reveal">
        <div class="er-visual">
          <img src="<%= item[:img] %>" alt="<%= item[:alt] %>" loading="lazy">
          <div class="er-overlay"></div>
          <span class="er-num"><%= item[:num] %></span>
        </div>
        <div class="er-content">
          <span class="er-tag"><%= item[:tag] %></span>
          <h3 class="er-title"><%= item[:title] %></h3>
          <p class="er-desc"><%= item[:desc] %></p>
          <p class="er-desc"><%= item[:extra] %></p>
          <ul class="er-list">
            <% item[:items].each do |point| %>
              <li><%= point %></li>
            <% end %>
          </ul>
        </div>
