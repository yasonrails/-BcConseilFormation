<!-- ═══════════════ SCRIPTS ═══════════════ -->
<script>
/* ── Cursor ── */
const cur=document.getElementById('cur'),ring=document.getElementById('ring');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;cur.style.left=mx+'px';cur.style.top=my+'px';},{passive:true});
(function anim(){rx+=(mx-rx)*.11;ry+=(my-ry)*.11;ring.style.left=rx+'px';ring.style.top=ry+'px';requestAnimationFrame(anim);})();

/* ── Scroll reveal ── */
const revels=document.querySelectorAll('.reveal');
const obs=new IntersectionObserver(es=>{es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('visible');obs.unobserve(e.target);}});},{threshold:.12});
revels.forEach(r=>obs.observe(r));

/* ── Login ── */
function openLogin(){
  document.getElementById('login-layer').style.display='block';
  document.body.style.overflow='hidden';
}
function closeLogin(e){
  if(e&&e.target!==document.querySelector('.login-overlay'))return;
  document.getElementById('login-layer').style.display='none';
  document.body.style.overflow='';
}
function enterPlatform(){
  document.getElementById('login-layer').style.display='none';
  document.getElementById('site-layer').style.display='none';
  document.getElementById('app-layer').style.display='block';
  document.body.style.overflow='hidden';
}
function exitPlatform(){
  document.getElementById('app-layer').style.display='none';
  document.getElementById('site-layer').style.display='block';
  document.body.style.overflow='';
  window.scrollTo({top:0,behavior:'smooth'});
}

/* ── Platform nav ── */
const views={
  'dashboard':'Tableau de <em>bord</em>',
  'catalogue':'Catalogue <em>formations</em>',
  'apprenant':'Espace <em>apprenant</em>',
  'messagerie':'Mes <em>conversations</em>',
  'admin':'Administration <em>plateforme</em>',
  'profil':'Mon <em>profil</em>'
};
function showV(id,navEl){
  document.querySelectorAll('.view').forEach(v=>v.classList.remove('active'));
  document.getElementById('v-'+id).classList.add('active');
  document.getElementById('ttitle').innerHTML=views[id]||id;
  if(navEl){document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));navEl.classList.add('active');}
  document.getElementById('appMain').scrollTo({top:0,behavior:'smooth'});
}
function toggleMod(hdr){
  const item=hdr.closest('.mi');
  const was=item.classList.contains('open');
  document.querySelectorAll('.mi').forEach(m=>m.classList.remove('open'));
  if(!was)item.classList.add('open');
}

/* ── AI Panel ── */
function openAiPanel(type) {
  document.getElementById('ai-modal').style.display = 'block';
  ['tutor','quiz','resume','path'].forEach(t => {
    const el = document.getElementById('ai-panel-'+t);
    if(el) el.style.display = (t === type) ? 'flex' : 'none';
  });
}
function closeAiPanel(e) {
  if (e && e.target !== document.getElementById('ai-modal')) return;
  document.getElementById('ai-modal').style.display = 'none';
}
function selectQuiz(btn, correct) {
  document.querySelectorAll('.quiz-opt').forEach(b => {
    b.disabled = true;
    b.classList.remove('correct','wrong');
  });
  btn.classList.add(correct ? 'correct' : 'wrong');
  document.getElementById('quiz-feedback').style.display = 'block';
}

</script>
