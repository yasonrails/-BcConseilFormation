<section class="ai-section" id="ia">
  <div class="ai-grid-bg"></div>
  <div class="ai-inner">

    <div class="ai-header">
      <p class="s-label reveal" style="color:rgba(255,255,255,.4);">05 — Intelligence Artificielle</p>
      <h2 class="s-title reveal" style="color:#fff;">La RH augmentée<br>par <em style="color:rgba(255,255,255,.45)">l'IA.</em></h2>
      <p class="s-desc reveal" style="color:rgba(255,255,255,.5);max-width:560px;margin-top:16px;">Nous intégrons des solutions LLM de pointe dans nos accompagnements pour accélérer votre transformation RH — analyse, génération, aide à la décision.</p>
    </div>

    <div class="ai-cards">

      <%# Card 1 — Featured %>
      <div class="ai-card ai-card--featured reveal">
        <div class="ai-card-glow"></div>
        <div class="ai-card-tag">Analyse documentaire</div>
        <h3 class="ai-card-title">Audit RH<br>assisté par IA</h3>
        <p class="ai-card-desc">Nos modèles LLM analysent vos conventions collectives, contrats et règlements intérieurs pour détecter automatiquement les non-conformités et opportunités d'optimisation.</p>
        <div class="ai-demo">
          <div class="ai-demo-label">Exemple de sortie LLM</div>
          <div class="ai-terminal">
            <div class="ai-terminal-line"><span class="ai-prompt">▸</span> Analyse contrat CDD en cours…</div>
            <div class="ai-terminal-line ai-typing"><span class="ai-prompt ai-green">✓</span> 3 clauses non-conformes détectées</div>
            <div class="ai-terminal-line"><span class="ai-prompt ai-amber">⚠</span> Clause 7.2 — Période d'essai excessive</div>
            <div class="ai-terminal-line"><span class="ai-prompt ai-amber">⚠</span> Clause 12 — Mentions RGPD manquantes</div>
            <div class="ai-terminal-line"><span class="ai-prompt">→</span> Recommandation générée — <em>voir rapport</em></div>
          </div>
        </div>
        <div class="ai-stack">
          <span class="ai-tech">GPT-4o</span>
          <span class="ai-tech">Claude 3.5</span>
          <span class="ai-tech">RAG juridique</span>
        </div>
      </div>

      <%# Card 2 %>
      <div class="ai-card reveal d1">
        <div class="ai-card-tag">Formation adaptative</div>
        <h3 class="ai-card-title">Parcours<br>personnalisés</h3>
        <p class="ai-card-desc">Un LLM analyse le profil, les lacunes et le rythme de chaque apprenant pour générer un plan de formation sur mesure, ajusté en temps réel.</p>
        <div class="ai-visual">
          <div class="ai-path-node active">Profil évalué</div>
          <div class="ai-path-arrow">→</div>
          <div class="ai-path-node">Lacunes identifiées</div>
          <div class="ai-path-arrow">→</div>
          <div class="ai-path-node">Parcours généré</div>
        </div>
        <div class="ai-stack">
          <span class="ai-tech">Fine-tuning</span>
          <span class="ai-tech">Embeddings</span>
        </div>
      </div>

      <%# Card 3 %>
      <div class="ai-card reveal d2">
        <div class="ai-card-tag">Aide à la décision</div>
        <h3 class="ai-card-title">Assistant RH<br>conversationnel</h3>
        <p class="ai-card-desc">Un agent IA disponible 24/7 qui répond aux questions RH complexes, génère des modèles de documents et guide les managers en temps réel.</p>
        <div class="ai-chat-demo">
          <div class="ai-chat-bubble user">Comment rédiger un PIP conforme ?</div>
          <div class="ai-chat-bubble bot">Je génère un modèle de Plan d'Amélioration des Performances adapté à votre convention collective, incluant les 6 éléments obligatoires…</div>
        </div>
        <div class="ai-stack">
          <span class="ai-tech">Agents IA</span>
          <span class="ai-tech">Tools API</span>
        </div>
      </div>

      <%# Card 4 %>
      <div class="ai-card reveal d1">
        <div class="ai-card-tag">Veille &amp; Conformité</div>
        <h3 class="ai-card-title">Veille juridique<br>automatisée</h3>
        <p class="ai-card-desc">Surveillance continue des évolutions du droit du travail. Notre pipeline LLM extrait, synthétise et alerte sur les changements réglementaires qui impactent votre organisation.</p>
        <div class="ai-counter">
          <div class="ai-counter-item">
            <span class="ai-counter-val">12k+</span>
            <span class="ai-counter-lbl">textes analysés/mois</span>
          </div>
          <div class="ai-counter-sep"></div>
          <div class="ai-counter-item">
            <span class="ai-counter-val">&lt;2h</span>
            <span class="ai-counter-lbl">délai d'alerte</span>
          </div>
        </div>
        <div class="ai-stack">
          <span class="ai-tech">Web scraping</span>
          <span class="ai-tech">NLP</span>
          <span class="ai-tech">Résumé auto</span>
        </div>
      </div>

      <%# Card 5 — Full width stack %>
      <div class="ai-card ai-card--wide reveal d2">
        <div class="ai-card-glow ai-card-glow--wide"></div>
        <div class="ai-card-wide-inner">
          <div>
            <div class="ai-card-tag">Notre stack technologique</div>
            <h3 class="ai-card-title">Intégré à votre<br>environnement existant.</h3>
            <p class="ai-card-desc">Nos solutions s'intègrent à vos SIRH, outils collaboratifs et bases documentaires — sans friction, sans rupture de données.</p>
          </div>
          <div class="ai-integrations">
            <div class="ai-int-row">
              <div class="ai-int-chip"><span>🤖</span> OpenAI GPT-4o</div>
              <div class="ai-int-chip"><span>🧠</span> Anthropic Claude</div>
            </div>
            <div class="ai-int-row">
              <div class="ai-int-chip"><span>🔗</span> LangChain RAG</div>
              <div class="ai-int-chip"><span>📊</span> Vector DB</div>
            </div>
            <div class="ai-int-row">
              <div class="ai-int-chip"><span>🔒</span> Données privées</div>
              <div class="ai-int-chip"><span>⚡</span> API REST</div>
            </div>
            <div class="ai-sovereignty">
              <span class="ai-sov-dot"></span>
              Souveraineté des données garantie — hébergement France
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
