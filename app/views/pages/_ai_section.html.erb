<%#
  ============================================================
  SECTION IA — Image de fond
  Remplacez ai_bg_image par : image_url("votre-image.jpg")
  Taille recommandée : 1920×1080px, format WebP ou JPEG.
  ============================================================
%>
<% ai_bg_image = "https://images.unsplash.com/photo-1451187580459-43490279c0fa?w=1920&q=80" %>

<%#
  ── DONNÉES DES CARDS ──────────────────────────────────────
  Ajoutez / retirez des cards ici sans toucher au HTML.
  Champs disponibles :
    tag      → libellé affiché en haut de card
    title    → titre (utiliser \n pour le saut de ligne)
    desc     → paragraphe descriptif
    benefits → tableau de points forts (icône ✓ auto)
    badges   → tableau de { label:, light: } (light = gris)
    featured → true pour la card mise en avant (fond bleu)
    delay    → classe CSS d'animation ("d1", "d2", nil)
  ───────────────────────────────────────────────────────────
%>
<% ai_cards = [
  {
    tag:      " Audit & Conformité",
    title:    "Analyse intelligente\nde vos documents RH",
    desc:     "Contrats, conventions, règlements intérieurs — vos documents sont passés en revue et les points à mettre à jour vous sont indiqués précisément, sans que vous ayez à tout relire.",
    benefits: [
      "Détection des points de non-conformité",
      "Rapport de recommandations clair et actionnable",
      "Gain de temps considérable sur vos audits"
    ],
    badges:   [{ label: "Disponible maintenant" }, { label: "Données hébergées en France", light: true }],
    featured: true
  },
  {
    tag:      " Analyse de CV",
    title:    "Sélection de candidats\nplus rapide et fiable",
    desc:     "Déposez vos CV et obtenez en quelques secondes un classement objectif des candidats selon vos critères — compétences, expérience, adéquation au poste — pour vous concentrer sur les entretiens.",
    benefits: [
      "Lecture et comparaison automatique des profils",
      "Scoring personnalisé selon votre fiche de poste",
      "Résumé structuré par candidat prêt à partager"
    ],
    badges:   [{ label: "Disponible maintenant" }],
    delay:    "d1"
  },
  {
    tag:      " Supports de formation",
    title:    "Créez vos supports\nen quelques clics",
    desc:     "Transformez vos notes, présentations ou thématiques en supports de formation complets et structurés — sans effort de mise en page, directement exploitables par vos formateurs.",
    benefits: [
      "Génération à partir d'un texte, d'un PDF ou d'un sujet",
      "Structure pédagogique claire et progressive",
      "Export prêt à l'emploi pour vos sessions"
    ],
    badges:   [{ label: "Disponible maintenant" }],
    delay:    "d2"
  },
  {
    tag:      " Modules interactifs",
    title:    "Des formations qui\nengagent vraiment",
    desc:     "À partir de vos supports existants, générez des modules interactifs avec quiz, mises en situation et points de validation — pour des apprenants qui progressent et restent motivés.",
    benefits: [
      "Quiz et évaluations générés automatiquement",
      "Parcours adapté au rythme de l'apprenant",
      "Suivi des résultats pour chaque participant"
    ],
    badges:   [{ label: "Disponible maintenant" }],
    delay:    "d1"
  },
  {
    tag:      " Parcours personnalisés",
    title:    "La bonne formation\npour la bonne personne",
    desc:     "Fini les formations génériques. Chaque collaborateur bénéficie d'un programme adapté à son poste, son niveau et ses objectifs, ajusté au fil de sa progression.",
    benefits: [
      "Profil de compétences établi automatiquement",
      "Plan de développement individuel sur mesure",
      "Recommandations mises à jour en temps réel"
    ],
    badges:   [{ label: "Sur devis" }],
    delay:    "d2"
  },
  {
    tag:      " Assistant RH",
    title:    "Un assistant disponible\nà tout moment",
    desc:     "Vos managers et équipes RH posent leurs questions et obtiennent des réponses précises accompagnées de modèles de documents prêts à l'emploi — sans attendre, sans chercher.",
    benefits: [
      "Réponses aux questions RH courantes et complexes",
      "Génération de modèles de documents conformes",
      "Disponible 24h/24, 7j/7"
    ],
    badges:   [{ label: "Disponible maintenant" }],
    delay:    "d1"
  },
] %>

<section class="ai-section" id="ia"<% if ai_bg_image.present? %> style="--ai-bg: url('<%= ai_bg_image %>');"<% end %>>
  <div class="ai-bg-overlay"></div>
  <div class="ai-inner">

    <div class="ai-header">
      <p class="s-label reveal" style="color:rgba(255,255,255,.45);">05 — Nos solutions IA</p>
      <h2 class="s-title reveal" style="color:#fff;">Une RH plus intelligente,<br><em style="color:rgba(255,255,255,.4)">dès aujourd'hui.</em></h2>
      <p class="s-desc reveal" style="color:rgba(255,255,255,.55);max-width:580px;margin-top:16px;">Des outils concrets, immédiatement opérationnels, conçus pour votre réalité terrain — sans complexité technique, avec un accompagnement humain à chaque étape.</p>
    </div>

    <div class="ai-cards">
      <% ai_cards.each_with_index do |card, i| %>
        <div class="ai-card<%= " ai-card--featured" if card[:featured] %> reveal<%= " #{card[:delay]}" if card[:delay] %>">
          <% if card[:featured] %><div class="ai-card-glow"></div><% end %>
          <div class="ai-card-tag"><%= card[:tag] %></div>
          <h3 class="ai-card-title"><%= card[:title].gsub("\n", "<br>").html_safe %></h3>
          <p class="ai-card-desc"><%= card[:desc] %></p>
          <div class="ai-benefits">
            <% card[:benefits].each do |benefit| %>
              <div class="ai-benefit-item">
                <span class="ai-benefit-icon">✓</span>
                <span><%= benefit %></span>
              </div>
            <% end %>
          </div>
          <div class="ai-badge-row">
            <% card[:badges].each do |badge| %>
              <span class="ai-badge<%= " ai-badge--light" if badge[:light] %>"><%= badge[:label] %></span>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <div class="ai-cta-strip reveal">
      <div class="ai-cta-strip-inner">
        <div>
          <p class="ai-cta-strip-title">Prêt à moderniser votre RH ?</p>
          <p class="ai-cta-strip-sub">Discutons de vos besoins et identifions les solutions les plus adaptées à votre organisation.</p>
        </div>
        <%= link_to "#contact", class: "btn ai-cta-btn" do %>
          Prendre contact <span>→</span>
        <% end %>
      </div>
      <div class="ai-cta-guarantees">
        <span> Confidentialité garantie</span>
        <span>🇫🇷 Hébergement France</span>
        <span> Sans engagement initial</span>
      </div>
    </div>

  </div>
</section>


<section class="ai-section" id="ia"
  <% if ai_bg_image.present? %>
    style="--ai-bg: url('<%= ai_bg_image %>');"
  <% end %>>

  <div class="ai-bg-overlay"></div>
  <div class="ai-inner">
    
  </div>
</section>
